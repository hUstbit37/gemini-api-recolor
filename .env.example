# Cookie từ gemini.google.com (F12 -> Application -> Cookies -> https://gemini.google.com)
# Bắt buộc: __Secure-1PSID. __Secure-1PSIDTS có thể trống với một số account.
SECURE_1PSID=
SECURE_1PSIDTS=

# --- Service (optional, giá trị dưới là mặc định) ---
# GEMINI_RECOLOR_HOST=127.0.0.1
# GEMINI_RECOLOR_PORT=8088
# GEMINI_MODEL=BASIC_FLASH          # model duy nhất trả ảnh ổn định
# GEMINI_INIT_TIMEOUT=60
# GEMINI_MAX_IMAGE_BYTES=10485760
# GEMINI_SAVE_OUTPUT=1              # 0 = không ghi ảnh ra output/
# GEMINI_OUTPUT_DIR=output
# GEMINI_PROMPT_TEMPLATE=...        # phải chứa {hex} và {name_part}
